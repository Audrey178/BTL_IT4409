# Application
NODE_ENV=development
PORT=3000
APP_NAME=Meeting Backend

# Database MongoDB
MONGODB_URI=mongodb://admin:admin123@localhost:27017/meeting_db?authSource=admin
MONGODB_USER=admin
MONGODB_PASSWORD=admin123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_key_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_token_secret_key_min_32_chars_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Server
ENABLE_SWAGGER=true
SWAGGER_PATH=/api-docs
